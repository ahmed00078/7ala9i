{
  "expo": {
    "name": "7ala9i",
    "slug": "7ala9i",
    "scheme": "halagi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F7A6C"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F7A6C",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.x7ala9i.x7ala9i",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-image",
      "expo-font",
      [
        "expo-notifications",
        {
          "defaultChannel": "default",
          "androidImportance": "high",
          "androidCollapsedTitle": "7ala9i",
          "icon": "./assets/notification-icon.png",
          "color": "#0F7A6C"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow 7ala9i to access your photos to upload salon photos.",
          "cameraPermission": "Allow 7ala9i to use the camera to take salon photos."
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://7ala9i-api.duckdns.org/api/v1",
      "eas": {
        "projectId": "704ec507-9b93-478e-9a01-93887b2fca12"
      }
    },
    "owner": "x7ala9i"
  }
}
