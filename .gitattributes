# Normalize all text files to LF on commit; check out with LF in working tree.
# Prevents CRLF churn when editing on Windows/WSL with editors that default to CRLF.
* text=auto eol=lf

# Source code
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.py        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.sh        text eol=lf

# Procfile / config-style files (no extension) — explicit
Procfile    text eol=lf
.env*       text eol=lf
Dockerfile  text eol=lf

# Windows-only scripts keep CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary assets
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.icns      binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.pdf       binary
*.zip       binary
*.tar.gz    binary
*.keystore  binary
*.jks       binary
*.apk       binary
*.aab       binary
